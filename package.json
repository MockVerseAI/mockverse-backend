{
  "name": "mockverse-backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-loader=newrelic/esm-loader.mjs ./dist/index.js",
    "start:dev": "node --experimental-loader=newrelic/esm-loader.mjs ./dist/index.js",
    "dev": "nodemon --exec node --experimental-loader ts-node/esm ./src/index.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs --detectOpenHandles",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs --coverage",
    "test:models": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs src/tests/models",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "lint-staged": "npx lint-staged"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@ai-sdk/google": "^1.1.10",
    "@ai-sdk/groq": "^1.1.7",
    "@ai-sdk/togetherai": "^0.1.12",
    "@aws-sdk/client-polly": "^3.749.0",
    "@aws-sdk/client-s3": "^3.624.0",
    "ai": "^4.1.24",
    "ai-fallback": "^0.1.1",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^15.2.11",
    "mailgen": "^2.0.28",
    "mongoose": "^8.10.1",
    "multer": "^1.4.5-lts.1",
    "newrelic": "^12.13.0",
    "nodemailer": "^6.9.14",
    "nodemon": "^3.1.9",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mailgen": "^2.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.9",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "./src/**/*.{js,jsx,ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "./src/**/*.{json,md,yml,css,scss,html}": [
      "npx prettier --write"
    ]
  }
}
